# =============================================================================
# 환경설정 예시 — 실제 값은 .env / .env.dev / .env.prod 에 채운다(이 파일만 Git 추적).
# =============================================================================
# 환경 분리 구조:
#   - .env        : dev/prod 공통 값
#   - .env.dev    : 개발(dev) 전용 값 (기본)
#   - .env.prod   : 운영(prod) 전용 값
# 로드 순서: .env → .env.<APP_ENV>  (뒤 파일이 공통값을 덮어씀)
# 환경 선택: OS 환경변수 APP_ENV(없으면 ENVIRONMENT, 기본 "dev")
#   예) APP_ENV=prod uvicorn app.main:app      →  .env + .env.prod
#       uvicorn app.main:app                   →  .env + .env.dev
# 시작하려면: cp .env.example .env.dev  후 값 채우기.
# =============================================================================

# ── 공통(.env) ───────────────────────────────────────────────────────────────
TOSS_API_BASE_URL=https://api.tosspayments.com
# 토스 웹훅 허용 IP(JSON 배열)
TOSS_WEBHOOK_ALLOWED_IPS=["13.124.18.147","13.124.108.35","3.36.173.151","3.38.81.32","115.92.221.121","115.92.221.122","115.92.221.123","115.92.221.125","115.92.221.126","115.92.221.127"]
SESSION_TTL_SECONDS=1800
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300
# HMAC nonce 보관(초) — 재전송 차단 윈도우(타임스탬프 허용오차보다 길게).
HMAC_NONCE_TTL_SECONDS=600
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PAYMENT_PER_MINUTE=20
# 어드민 로그인 분당 허용 횟수(무차별 로그인 방지).
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
# 어드민 계정 보안 정책: 연속 실패 잠금 임계치 / 잠금 시간(분) / 비밀번호 최소 길이.
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15
MIN_PASSWORD_LENGTH=10
# 비밀번호 설정·재설정 링크 유효시간(시간).
PASSWORD_LINK_TTL_HOURS=48
# 단건(일반) 결제 1회 최대 금액(원) — 기본값보다 올리려면 schemas/api.py le= 도 함께 상향.
ONE_OFF_MAX_AMOUNT=100000000
# 토스 API HTTP 타임아웃(초): read는 자동결제 승인 최대 60초+여유, connect는 짧게.
TOSS_READ_TIMEOUT_SECONDS=65
TOSS_CONNECT_TIMEOUT_SECONDS=5
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=5
# 갱신 배치 Redis 전역 락 TTL(초, 데드맨 스위치) / 배치 1회당 카테고리별 처리 상한.
SCHEDULER_LOCK_TTL_SECONDS=240
RENEWAL_BATCH_LIMIT=1000
# 엑셀 다운로드 1건 최대 행 수(워커 OOM 방지).
EXPORT_MAX_ROWS=100000
RETRY_INTERVAL_HOURS=12
RETRY_LIMIT=4
SUSPENDED_GRACE_DAYS=30
# Gmail 앱 비밀번호(16자) 사용. 둘 다 설정 시 실제 발송.
GMAIL_ID=
GMAIL_PW=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_FROM_NAME=결제시스템

# ── 환경별(.env.dev / .env.prod) ──────────────────────────────────────────────
ENVIRONMENT=dev
BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://payment:Payment!2002@localhost:5432/payment
# dev DB 비밀번호 — docker-compose.dev.yml이 DATABASE_URL의 ${DB_PASSWORD} 치환에 사용(컨테이너는 host.docker.internal로 호스트 DB에 붙음)
DB_PASSWORD=Payment!2002
REDIS_URL=redis://localhost:6380/0
# AES-256-GCM 키(base64 32바이트). 생성: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=
# 토스 시크릿 키: dev=test_sk_*, prod=live_sk_*
TOSS_SECRET_KEY=test_sk_xxxx
# 리버스 프록시 뒤(prod)면 true
TRUST_PROXY=false
# 신뢰 프록시 단(hop) 수 — XFF의 '오른쪽에서 n번째'를 클라이언트 IP로 사용(위조 방어).
# 클라이언트→nginx→앱 = 1, 클라이언트→LB→nginx→앱 = 2
TRUST_PROXY_HOPS=1
# DB 커넥션 풀(총 최대 = POOL_SIZE + MAX_OVERFLOW). 기본 10+20 — 워크로드에 맞게 조정.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# 운영은 true 권장
WEBHOOK_IP_CHECK_ENABLED=true
# 개발 편의(prod에서는 무시)
DEV_LOGIN_EMAIL=
DEV_LOGIN_PASSWORD=
# /docs(Swagger) HTTP Basic 계정. 둘 다 설정해야 docs 노출, 비우면 404.
SWAGGER_ID=admin
SWAGGER_PW=change-me
