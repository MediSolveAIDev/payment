# PostgreSQL 단독 인스턴스 설정 — db_server/run.sh 가 읽는다.
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채운다(비밀번호 반드시 변경). .env 는 커밋 금지.
#   cp .env.example .env

# ── 컨테이너 / 이미지 ─────────────────────────────────────────────────────────
POSTGRES_CONTAINER=payment-postgres
# 앱(payment_system)과 동일 메이저 버전(16)으로 맞춘다 — pg_dump/복원 호환.
POSTGRES_IMAGE=postgres:16-alpine

# ── 계정 / DB (앱의 DATABASE_URL 과 반드시 일치) ──────────────────────────────
POSTGRES_USER=payment
POSTGRES_PASSWORD=__CHANGE_ME__강력한_비밀번호로_변경__
POSTGRES_DB=payment

# ── 포트 노출 ────────────────────────────────────────────────────────────────
# 보안 핵심: 가능하면 사설 IP 에만 바인딩한다(예: HOST_BIND=10.0.0.5).
#  0.0.0.0 은 모든 인터페이스에 열리므로, 그 경우 방화벽/보안그룹에서 "앱서버 IP만"
#  5432 를 허용해야 한다. DB 는 인터넷에 직접 노출 금지.
HOST_BIND=0.0.0.0
HOST_PORT=5432

# ── 데이터 저장 위치 ─────────────────────────────────────────────────────────
# 기본은 Docker "명명 볼륨"(호스트 디렉터리 생성/권한 불필요 — root 없이 동작).
DATA_VOLUME=payment_pgdata
# 특정 디스크/경로에 저장하려면 아래 DATA_DIR 의 주석을 풀고 경로를 지정한다.
#  - 비어 있으면 위 DATA_VOLUME(명명 볼륨)을 사용한다.
#  - 호스트 경로를 쓰려면 그 경로에 "쓰기 권한"이 있어야 한다(없으면 run.sh가 안내).
#    예) DATA_DIR=$HOME/payment-postgres/data
#    전용 디스크(예: /data/postgres)를 쓰려면 미리:
#      sudo mkdir -p /data/postgres && sudo chown $(id -u):$(id -g) /data/postgres
#DATA_DIR=

# ── 타임존 ───────────────────────────────────────────────────────────────────
TZ=Asia/Seoul

# ── (선택) 성능 튜닝 — 인스턴스 RAM 에 맞춰. 비우면 PostgreSQL 기본값 사용 ──────
# 권장 시작점: shared_buffers ≈ RAM 의 25% (예: 16GB → 4GB)
PG_SHARED_BUFFERS=
PG_MAX_CONNECTIONS=
