DJANGO_SECRET_KEY=change-me
DEBUG=True
# 구독서버(payment_system) 베이스 URL — 포트 포함(uvicorn 기본 8000)
PAYMENT_API_BASE=http://127.0.0.1:8000
# 토스 빌링 인증(카드 등록) client key — 비우면 /card 화면의 수동 authKey 폴백으로 테스트
TOSS_CLIENT_KEY=test_ck_ex6BJGQOVD9YZDN6jvwqrW4w2zNb

# ── 외부 접근(미설정 시 로컬/도커 전용) ───────────────────────────────────────
# 외부 도메인/IP로 접속하려면 둘 다 설정. docker-compose 기본값이 nginx 8001 도메인이라
# 같은 도메인이면 생략 가능. 값을 바꾸면 아래를 채운다(콤마로 여러 개).
# ALLOWED_HOSTS: 허용 Host (콤마 구분). "*" 는 전체 허용(데모 한정).
ALLOWED_HOSTS=api-stg-pay.medisolveai.com
# CSRF_TRUSTED_ORIGINS: 폼 제출 origin (스킴+호스트[:포트], 콤마 구분). POST 폼 403 방지.
CSRF_TRUSTED_ORIGINS=http://api-stg-pay.medisolveai.com:8001
